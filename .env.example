# .env.example — скопируйте в .env для локальной разработки

# Обязательные
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
HF_API_KEY=your_huggingface_access_token

# Доступ (пусто = открыт для всех; иначе Telegram user_id через запятую)
ALLOWED_USER_IDS=

# Опциональные
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Redis (опционально; docker-compose подставляет redis://redis:6379/0)
REDIS_URL=

# Sentry (опционально)
SENTRY_DSN=

# Вебхук (продакшн; пусто = polling)
WEBHOOK_HOST=
WEBHOOK_SECRET=
PORT=8080
ENABLE_HEALTH_SERVER=0

# Генерация
# HF_AUDIO_BACKEND=fal — Stable Audio 3 через HF Inference Providers (нужен токен с правом Providers)
# FAL_HUB_AUDIO_MODEL=stabilityai/stable-audio-3-medium
# FAL_API_KEY= — прямой ключ fal.ai (обходит лимит HF-кредитов): fal.ai/dashboard/keys
# Можно также задать как FAL_KEY (как в документации fal.ai)
HF_AUDIO_BACKEND=fal
GENERATION_VARIANTS=3
# При необходимости переопределите (по умолчанию — router.huggingface.co):
# HF_MUSICGEN_MODEL_URL=https://router.huggingface.co/hf-inference/models/facebook/musicgen-small
# HF_AUDIOLDM_MODEL_URL=https://router.huggingface.co/hf-inference/models/haoheliu/audioldm
AUTO_MASTER_POLISH=1
SHOW_IMPROVED_PROMPT=1
DAILY_GENERATION_LIMIT=30
MAX_EXTENDED_MUSIC_DURATION_SECONDS=90
MUSIC_SEGMENT_CROSSFADE_SECONDS=0.5

# Прочее
HF_REQUEST_TIMEOUT_SECONDS=120
HF_MAX_RETRIES=5
HF_RETRY_DELAY_SECONDS=10
HF_MAX_CONCURRENT_REQUESTS=2
TMP_FILE_TTL_SECONDS=1800
THROTTLE_RATE_SECONDS=1.0
LIBRARY_PAGE_SIZE=5
